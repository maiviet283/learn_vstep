# Copy file này thành .env rồi điền giá trị thật vào

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://vstep.vietdon.vn

# Database (Supabase PostgreSQL)
